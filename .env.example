# ═══════════════════════════════════════════════════════════════
#  JUS CHIRI — Variables de entorno
#  Copia este archivo a .env y completa los valores reales.
#  NUNCA subas .env a git.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# BACKEND — Node.js / Express
# ───────────────────────────────────────────────────────────────

# Entorno de ejecución: development | production
NODE_ENV=development

# Puerto del servidor local (solo dev; en Netlify Functions no aplica)
PORT=4000

# ───────────────────────────────────────────────────────────────
# BASE DE DATOS — MongoDB Atlas
# Obtén la URI en: Atlas → Connect → Drivers → Node.js
# ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/juschiri?retryWrites=true&w=majority

# ───────────────────────────────────────────────────────────────
# CORS — URL del frontend
# En producción: tu dominio Netlify o dominio custom
# ───────────────────────────────────────────────────────────────
FRONTEND_URL=https://juschiri.netlify.app

# ───────────────────────────────────────────────────────────────
# AWS S3 — Almacenamiento de imágenes de productos
# IAM → Usuarios → Crear usuario → Adjuntar política AmazonS3FullAccess
# ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=juschiri-products
S3_REGION=us-east-1
# Carpeta dentro del bucket donde se guardan las imágenes
S3_FOLDER=products

# ───────────────────────────────────────────────────────────────
# SCRIPT DE MIGRACIÓN — Google Sheets
# La URL del sheet: https://docs.google.com/spreadsheets/d/{ID}/edit
# El sheet debe ser público (compartir → cualquier persona con el enlace)
# ───────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=<id_del_google_sheet>

# (Opcional) Si quieres que el script importe los productos al backend
# automáticamente al finalizar la migración. Dejar vacío para omitir.
API_URL=
